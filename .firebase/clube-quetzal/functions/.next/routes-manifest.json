      "namedRegex": "^/api/pontuacao(?:/)?$"
    },
    {
      "page": "/api/pontuacao/membros",
      "regex": "^/api/pontuacao/membros(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/pontuacao/membros(?:/)?$"
    },
    {
      "page": "/api/pontuacao/resumo",
      "regex": "^/api/pontuacao/resumo(?:/)?$",
