// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth Models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  membro        Membro?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Unidade {
  id        String   @id @default(cuid())
  nome      String   @unique // Falcão, Águia, Pardal...
  membros   Membro[]
}

enum Role {
  DIRETORIA
  SECRETARIA
  LIDERANCA
  MEMBRO
}

enum Cargo {
  // Diretoria
  DIRETOR
  DIRETOR_ASSOCIADO
  SECRETARIO
  TESOUREIRO
  INSTRUTOR
  CAPELAO
  
  // Liderança de Unidade
  CONSELHEIRO
  CAPITAO
  SECRETARIO_UNIDADE
  TESOUREIRO_UNIDADE
  ALMOXARIFE
  
  // Membro comum
  DESBRAVADOR
}

model Membro {
  id           String      @id @default(cuid())
  nome         String
  email        String?
  googleEmail  String?
  passwordHash String?
  role         Role        @default(MEMBRO)
  cargo        Cargo       @default(DESBRAVADOR)
  unidadeId    String
  unidade      Unidade     @relation(fields: [unidadeId], references: [id])
  pontos       Pontuacao[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  userId      String?     @unique
  user        User?       @relation(fields: [userId], references: [id])

  @@unique([googleEmail])
}

model Pontuacao {
  id                String   @id @default(cuid())
  data              DateTime @default(now())
  membroId          String
  membro            Membro   @relation(fields: [membroId], references: [id])
  
  // PONTUAÇÃO DIÁRIA
  kitEspiritual     Int      @default(0) // 20 pts
  lenco             Int      @default(0) // 20 pts
  pontualidade      Int      @default(0) // 100 pts
  cantil            Int      @default(0) // 20 pts
  bandeirim         Int      @default(0) // 20 pts
  uniformeDomingo   Int      @default(0) // A DEFINIR
  
  // PONTUAÇÃO SECUNDÁRIA
  atividadeCartao   Int      @default(0) // 100 pts
  especialidade     Int      @default(0) // 200 pts
  presencaEventos   Int      @default(0) // 100 pts
  visita            Int      @default(0) // A DEFINIR
  
  // DINÂMICAS
  dinamicas         Int      @default(0) // 5000 a 4500 pts
  
  // PERDA DE PONTOS (Valores negativos)
  indisciplina      Int      @default(0) // -100
  xingamentos       Int      @default(0) // -200
  ofensa            Int      @default(0) // -500
  agressao          Int      @default(0) // -1000
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  version   String
  startDate DateTime @default(now())
  endDate   DateTime?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}